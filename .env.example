# ====== AI Tutor Configuration Example ======
# Rename this file to .env and fill in the values

# ====== Server ======
PORT=5000
NODE_ENV=development
HOST=0.0.0.0

# ====== Database ======
# MongoDB URL used by all services
MONGO_URI=mongodb://mongo:27017/ai_tutor_v2

# ====== JWT Auth ======
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ====== AI API ======
# Replace with your actual Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ====== Caching & Job Queue (Phase 3) ======
REDIS_HOST=redis
REDIS_PORT=6379

# ====== Microservice URLs ======
# If running via Docker Compose, these match the service names
AUTH_SERVICE_URL=http://auth:3001
LEARNING_SERVICE_URL=http://learning:3002
ASSESSMENT_SERVICE_URL=http://assessment:3003
AICHAT_SERVICE_URL=http://ai-chat:3004

# ====== Logging ======
LOG_LEVEL=info
MONGODB_LOG_LEVEL=error
